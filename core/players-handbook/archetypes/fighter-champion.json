    {
      "description": "<p>Beginning when you choose this archetype at 3rd level, your weapon attacks score a critical hit on a roll of 19 or 20.</p>",
      "id": "ID_WOTC_PHB_ARCHETYPE_FEATURE_IMPROVEDCRITICAL",
      "name": "Improved Critical",
      "requirements": "!ID_INTERNAL_FEATURE_REPLACEMENT_FIGHTER_CHAMPION_IMPROVED_CRITICAL",
      "sheet": "Your weapon attacks score a critical hit on a roll of 19 or 20.",
      "source": "Player's Handbook",
      "type": "Archetype Feature"
    },
    {
      "description": "<p>Starting at 7th level, you can add half your proficiency bonus (round up) to any Strength, Dexterity, or Constitution check you make that doesn't already use your proficiency bonus.</p> <p class=\"indent\">In addition, when you make a running long jump, the distance you can cover increases by a number of feet equal to your Strength modifier.</p>",
      "id": "ID_WOTC_PHB_ARCHETYPE_FEATURE_REMARKABLEATHLETE",
      "name": "Remarkable Athlete",
      "requirements": "!ID_INTERNAL_FEATURE_REPLACEMENT_FIGHTER_CHAMPION_REMARKABLE_ATHLETE",
      "rules": {
        "stat": [
          {
            "name": "acrobatics:misc",
            "requirements": "!ID_PROFICIENCY_SKILL_ACROBATICS",
            "value": "proficiency:half:up"
          },
          {
            "name": "athletics:misc",
            "requirements": "!ID_PROFICIENCY_SKILL_ATHLETICS",
            "value": "proficiency:half:up"
          },
          {
            "name": "sleight of hand:misc",
            "requirements": "!ID_PROFICIENCY_SKILL_SLEIGHTOFHAND",
            "value": "proficiency:half:up"
          },
          {
            "name": "stealth:misc",
            "requirements": "!ID_PROFICIENCY_SKILL_STEALTH",
            "value": "proficiency:half:up"
          }
        ]
      },
      "sheet": "When you make a running long jump, the distance you can cover increases by {{strength:modifier}} feet.",
      "source": "Player's Handbook",
      "type": "Archetype Feature"
    },
    {
      "description": "<p>At 10th level, you can choose a second option from the Fighting Style class feature.</p>",
      "id": "ID_WOTC_PHB_ARCHETYPE_FEATURE_ADDITIONALFIGHTINGSTYLE",
      "name": "Additional Fighting Style",
      "requirements": "!ID_INTERNAL_FEATURE_REPLACEMENT_FIGHTER_CHAMPION_ADDITIONAL_FIGHTING_STYLE",
      "rules": {
        "select": {
