          "name": "Additional Fighting Style",
          "supports": "Fighting Style, Fighter",
          "type": "Class Feature"
        }
      },
      "sheet": "You adopt a second style of fighting as your specialty.",
      "source": "Player's Handbook",
      "type": "Archetype Feature"
    },
    {
      "description": "<p>Starting at 15th level, your weapon attacks score a critical hit on a roll of 18–20.</p>",
      "id": "ID_WOTC_PHB_ARCHETYPE_FEATURE_SUPERIORCRITICAL",
      "name": "Superior Critical",
      "requirements": "!ID_INTERNAL_FEATURE_REPLACEMENT_FIGHTER_CHAMPION_SUPERIOR_CRITICAL",
      "sheet": "Your weapon attacks score a critical hit on a roll of 18–20.",
      "source": "Player's Handbook",
      "type": "Archetype Feature"
    },
    {
      "description": "<p>At 18th level, you attain the pinnacle of resilience in battle. At the start of each of your turns, you regain hit points equal to 5 + your Constitution modifier if you have no more than half of your hit points left. You don't gain this benefit if you have 0 hit points.</p>",
      "id": "ID_WOTC_PHB_ARCHETYPE_FEATURE_SURVIVOR",
      "name": "Survivor",
      "requirements": "!ID_INTERNAL_FEATURE_REPLACEMENT_FIGHTER_CHAMPION_SURVIVOR",
