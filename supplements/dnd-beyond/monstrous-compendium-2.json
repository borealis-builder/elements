          "supports": "ID_WOTC_MCV2_MAGIC_ITEM_NIGHTBRINGER_ACID|ID_WOTC_MCV2_MAGIC_ITEM_NIGHTBRINGER_COLD|ID_WOTC_MCV2_MAGIC_ITEM_NIGHTBRINGER_FIRE|ID_WOTC_MCV2_MAGIC_ITEM_NIGHTBRINGER_LIGHTNING|ID_WOTC_MCV2_MAGIC_ITEM_NIGHTBRINGER_POISON",
